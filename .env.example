# Copy to `.env` and set your Keycloak issuer(s). Only these vars are read by
# docker-compose.yml.

# ─── OIDC / Keycloak — required for authenticated routes ─────────────────────────
# Issuer = browser-facing Keycloak URL (the token `iss`), also reachable from the
# api container for JWKS. Empty ⇒ realm off ⇒ its tokens 401 (login works, API 401).

# Customer console — `clients` realm:
STRATOS_OAUTH2_ISSUER=https://id.example.com/realms/clients
STRATOS_OAUTH2_CLIENT_ID=stratos-ui

# Operator / admin console — `master` realm:
STRATOS_ADMIN_OAUTH2_ISSUER=https://id.example.com/realms/master
STRATOS_ADMIN_OAUTH2_CLIENT_ID=stratos-admin

# Machine Admin API — defaults to the admin issuer + `stratos-admin-api`; override:
# STRATOS_ADMIN_API_OAUTH2_ISSUER=https://id.example.com/realms/master
# STRATOS_ADMIN_API_OAUTH2_CLIENT_ID=stratos-admin-api

# ─── OpenStack — optional; unset keeps the cloud client disabled ─────────────────
# OS_AUTH_URL=https://keystone.example.com/v3
# OS_REGION_NAME=RegionOne
# OS_USERNAME=
# OS_PASSWORD=
# OS_USER_DOMAIN_NAME=Default
# OS_PROJECT_NAME=
# OS_PROJECT_DOMAIN_NAME=Default
